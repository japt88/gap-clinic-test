
@{
    ViewBag.Title = "CreatePatient";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Create Patient</h2>

<form id="createPatientForm">
    <div class="row">
        <div class="col-8">
            <div class="form-group">
                <label for="idNumberText">Identification Number</label>
                <input type="text" class="form-control" id="idNumberText" aria-describedby="emailHelp" placeholder="Enter Id Number">
            </div>
            <div class="form-group">
                <label for="firstNameText">First Name</label>
                <input type="text" class="form-control" id="firstNameText" placeholder="First Name">
            </div>
            <div class="form-group">
                <label for="lastNameText">Last Name</label>
                <input type="text" class="form-control" id="lastNameText" placeholder="Last Name">
            </div>
            <button type="submit" class="btn btn-primary">Submit</button>
        </div>
    </div>
</form>


<!-- Modal -->
<div id="patientModal" tabindex="-1" role="dialog" class="modal hide fade">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Patient</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div id="textResult"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts
{
    <script type="text/javascript">

        $(document).ready(function () {

            $("#createPatientForm").submit(function (e) {
                e.preventDefault();

                var patientInfo = {
                    identificationNumber: $("#idNumberText").val(),
                    firstName: $("#firstNameText").val(),
                    lastName: $("#lastNameText").val()

                };

                $.ajax({
                    type: "POST",
                    url: "http://localhost:44379/api/patient/",
                    data: JSON.stringify(patientInfo),
                    dataType: 'json',
                    contentType: 'application/json',
                    success: function (result) {
                        $("#textResult").text(result.Message);
                        $('#patientModal').modal('show');
                    }
                });
            });
        });
    </script>
}